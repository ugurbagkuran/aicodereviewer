# ============================================
# AI Code Reviewer — Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur
# cp .env.example .env
# ============================================

# --- App ---
APP_NAME=AI Code Reviewer
APP_VERSION=0.1.0
DEBUG=true

# --- MongoDB Atlas ---
# Atlas'tan connection string al: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=ai_code_reviewer

# --- JWT ---
# Güçlü bir secret key üret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-super-secret-key-generate-a-strong-one
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS ---
# Virgülle ayrılmış origin listesi
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Domain ---
BASE_DOMAIN=localhost

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute

# --- Redis (ileride aktif edilecek) ---
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# --- OpenRouter (AI Model - Gemma 4 27B) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=google/gemma-4-27b-it

# --- Google Embedding ---
GOOGLE_API_KEY=
EMBEDDING_MODEL=text-embedding-004

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Kubernetes ---
K8S_IN_CLUSTER=false
K8S_NAMESPACE_PREFIX=project-

# --- Container Kapasite Yönetimi ---
MAX_ACTIVE_PODS=12
MAX_PODS_PER_USER=0
IDLE_TIMEOUT_MINUTES=15

# --- Pod Resource Limitleri ---
POD_CPU_REQUEST=200m
POD_CPU_LIMIT=500m
POD_MEMORY_REQUEST=256Mi
POD_MEMORY_LIMIT=512Mi
SIDECAR_CPU_REQUEST=100m
SIDECAR_CPU_LIMIT=200m
SIDECAR_MEMORY_REQUEST=64Mi
SIDECAR_MEMORY_LIMIT=128Mi
